# Full URL of your OpenAI-compatible chat/completions endpoint
UPSTREAM_BASE_URL=https://your-gateway.example.com/v1/chat/completions

# API key sent to the upstream (leave empty to forward the inbound key)
UPSTREAM_API_KEY=

# Optional token this proxy requires from callers (set to empty to disable auth)
GATEWAY_API_KEY=local-dev-token

# Default model name sent upstream when no mapping matches
DEFAULT_UPSTREAM_MODEL=claude-sonnet-4-5

# Fallback max_tokens budget
DEFAULT_MAX_TOKENS=32000

# When true, every request is pinned to DEFAULT_UPSTREAM_MODEL regardless of what the client asks for
FORCE_UPSTREAM_MODEL=false

# Pretty Rich panels in the terminal
PRETTY_LOGS=true

# Truncate payload previews after this many characters
LOG_PAYLOAD_MAX_CHARS=1400

# JSON object mapping client-facing model names to upstream model names
MODEL_MAP_JSON={"claude-sonnet-4-5":"claude-sonnet-4-5-v1","claude-opus-4-5":"claude-opus-4-5-v1"}

HOST=127.0.0.1
PORT=8000
UPSTREAM_TIMEOUT_SECONDS=180
